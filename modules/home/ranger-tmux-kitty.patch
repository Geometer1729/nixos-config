+
+        if self.is_tmux:
+            wrapped = b'%s%s%s' % (
+                self.tmux_protocol_start,
+                wrapped.replace(b'\x1b', b'\x1b\x1b'),
+                self.tmux_protocol_end,
+            )
+        return wrapped
+
+    def _write(self, msg, wrap=True):
+        # Print codes, wrapped into protocol if needed.
+        if wrap:
+            self.stdbout.write(self._wrap_byte_string(msg))
+        else:
