+    def _wrap_byte_string(self, msg):
+        # Wrap byte string into protocol.
+        # With tmux passthrough if inside tmux.
+        wrapped = b'%s%s%s' % (
+            self.protocol_start,
+            msg,
+            self.protocol_end
